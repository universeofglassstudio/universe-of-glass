---
import type { CollectionEntry } from 'astro:content';
import { type Lang, localizePath } from '../i18n/translations';

export interface Props {
  artwork: CollectionEntry<'artworks'>;
  lang: Lang;
}

const { artwork, lang } = Astro.props;
const data = artwork.data;
const title = lang === 'en' ? data.title_en : data.title_ro;
const price = lang === 'en' ? data.price_en : data.price_ro;
const href = localizePath(`/gallery/${artwork.slug}`, lang);
const thumb = data.images[0];
---
<a href={href} class="group bg-eleganceGrey/20 border border-eleganceGrey/40 overflow-hidden cursor-pointer hover:border-glassGreen/50 transition-colors duration-300 block">
  <div class="aspect-square w-full bg-baseDark overflow-hidden">
    <img
      src={thumb}
      alt={title}
      loading="lazy"
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out opacity-90 group-hover:opacity-100"
    />
  </div>
  <div class="p-6 flex justify-between items-center bg-baseDark">
    <h3 class="serif-font text-lg md:text-xl font-medium text-warmCream">{title}</h3>
    <span class="text-sm font-semibold text-glassGreen">{price}</span>
  </div>
</a>
